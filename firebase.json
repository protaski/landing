{
  "database": {
    "rules": "database.rules.json"
  },
  "hosting": {
    "public": "public",
    "cleanUrls": true,
    "trailingSlash": false,
    "headers": [{
      "source": "**",
      "headers": [{
          "key": "Content-Security-Policy-Report-Only",
          "value": "default-src 'self'; script-src 'report-sample' 'self'; style-src 'report-sample' 'self' https://fonts.googleapis.com; object-src 'none'; base-uri 'self'; connect-src 'self'; font-src 'self' https://fonts.gstatic.com; frame-src 'self'; img-src 'self'; manifest-src 'self'; media-src 'self'; report-uri https://5ffa8a73937fe147894b833d.endpoint.csper.io/; worker-src 'none';"
        }, {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }],
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "redirects": [{
        "regex": "/privacy/.*",
        "destination": "https://protaski.com/privacy",
        "type": 301

      },
      {
        "regex": "/terms/.*",
        "destination": "https://protaski.com/terms",
        "type": 301

      }
    ]
  }
}