{
  "hosting": {
    "public": "public",
    "cleanUrls": true,
    "trailingSlash": false,
    "headers": [{
      "source": "**",
      "headers": [{
          "key": "Content-Security-Policy",
          "value": "script-src 'self' https://cdn.firebase.com https://*.firebaseio.com; object-src 'self'"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        }
      ]
    }],
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "redirects": [{
        "regex": "/privacy/.*",
        "destination": "https://protaski.com/privacy",
        "type": 301

      },
      {
        "regex": "/terms/.*",
        "destination": "https://protaski.com/terms",
        "type": 301

      }
    ]
  }
}